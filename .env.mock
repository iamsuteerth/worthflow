# Local development env — loaded by `npm run dev:mock` (vite --mode mock).
# Contains no secrets, so it is committed. Auth + saves run entirely
# locally: MockAuthService (localStorage) + localstack S3.
#
# For cloud saves to work, start localstack first:
#   docker compose -f docker-compose-local.yml up -d
# Auth/UI work without it; only save/load needs the S3 endpoint.
VITE_AUTH_MODE=mock
VITE_AWS_REGION=ap-south-1
VITE_S3_BUCKET_NAME=worth-flow-saves
VITE_S3_ENDPOINT=http://localhost:4566
